---
layout: null
permalink: /assets/data/docs-preview-index.json
---
{
  "site": {
    "title": {{ site.title | jsonify }},
    "baseurl": {{ site.baseurl | jsonify }},
    "language": "{{ site.language | default: 'es' }}"
  },
  "generated_at": "{{ site.time | date_to_xmlschema }}",
  "items": [
    {% assign all_pages = site.pages | where_exp: "item", "item.title" %}
    {% assign filtered_pages = all_pages | where_exp: "item", "item.url != '/'" | sort: "url" %}
    {% for doc in filtered_pages %}
      {% assign raw_summary = doc.preview_summary | default: doc.excerpt | default: doc.content %}
      {% assign clean_summary = raw_summary | strip_html | strip_newlines | replace: "  ", " " | strip %}
      {% assign doc_author = doc.author | default: site.author | default: "" %}
      {
        "id": {{ doc.path | jsonify }},
        "title": {{ doc.title | jsonify }},
        "url": {{ doc.url | relative_url | jsonify }},
        "path": {{ doc.path | jsonify }},
        "summary": {{ clean_summary | truncate: 220 | jsonify }},
        "chapter": {{ doc.chapter | default: "" | jsonify }},
        "sidebar": {{ doc.sidebar | default: "docs" | jsonify }},
        "preview_image": {{ doc.preview_image | default: "" | jsonify }},
        "tags": {% if doc.preview_tags %}{{ doc.preview_tags | jsonify }}{% else %}[]{% endif %},
        "author": {{ doc_author | jsonify }},
        "published": {% if doc.draft %}false{% else %}true{% endif %}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}